{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build cstar",
      "type": "shell",
      "command": "${workspaceFolder}/build.bat",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc",
        "$msCompile"
      ]
    },
    {
      "label": "Run cstar smoke suite",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/tools/run_examples.ps1"
      ],
      "dependsOn": "Build cstar",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
