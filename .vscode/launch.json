{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug feature_lab: MSYS2 GDB",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build-ucrt/cstar.exe",
      "args": [
        "${workspaceFolder}/examples/interactive/feature_lab.cstar",
        "--run"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/build-ucrt/example-runs",
      "environment": [
        {
          "name": "PATH",
          "value": "C:\\msys64\\ucrt64\\bin;C:\\msys64\\usr\\bin;${env:PATH}"
        },
        {
          "name": "CSTAR_OUTPUT_DIR",
          "value": "${workspaceFolder}/build-ucrt/example-runs/.cstar-out"
        }
      ],
      "externalConsole": true,
      "MIMode": "gdb",
      "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
      "setupCommands": [
        {
          "description": "Enable GDB pretty printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "Build cstar"
    },
    {
      "name": "Debug cstar: Ninja/Clang",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build-ucrt/cstar.exe",
      "args": [
        "${workspaceFolder}/examples/smoke/minimal.cstar",
        "--run"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "PATH",
          "value": "C:\\msys64\\ucrt64\\bin;C:\\msys64\\usr\\bin;${env:PATH}"
        }
      ],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
      "preLaunchTask": "Build cstar"
    },
    {
      "name": "Debug cstar: Visual Studio",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/Debug/cstar.exe",
      "args": [
        "${workspaceFolder}/examples/smoke/minimal.cstar",
        "--run"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "console": "integratedTerminal",
      "preLaunchTask": "Build cstar"
    }
  ]
}
