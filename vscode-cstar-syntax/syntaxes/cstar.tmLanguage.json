{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "C*",
  "scopeName": "source.cstar",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#characters" },
    { "include": "#imports" },
    { "include": "#declarations" },
    { "include": "#operators" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#functions" },
    { "include": "#members" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.cstar",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-slash.cstar",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.cstar",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.cstar",
              "match": "\\\\(x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|U[0-9A-Fa-f]{8}|[0-7]{1,3}|[abfnrtv\\\\'\"?0])"
            },
            {
              "name": "constant.other.placeholder.cstar",
              "match": "%([-+ #0]*)(\\d+|\\*)?(\\.(\\d+|\\*))?(hh|h|ll|l|j|z|t|L)?[diuoxXfFeEgGaAcspn%]"
            }
          ]
        }
      ]
    },
    "characters": {
      "patterns": [
        {
          "name": "string.quoted.single.cstar",
          "match": "'([^'\\\\]|\\\\(x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|U[0-9A-Fa-f]{8}|[0-7]{1,3}|[abfnrtv\\\\'\"?0]))'"
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "meta.import.cstar",
          "begin": "\\b(import)\\s+(from)\\b",
          "beginCaptures": {
            "1": { "name": "keyword.control.import.cstar" },
            "2": { "name": "keyword.control.import.from.cstar" }
          },
          "end": "(?=\\{|;|$)",
          "patterns": [
            { "include": "#strings" },
            {
              "name": "entity.name.namespace.cstar",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*(::|;|\\{|$))"
            }
          ]
        },
        {
          "name": "meta.include.cstar",
          "begin": "\\b(include)\\b",
          "beginCaptures": {
            "1": { "name": "keyword.control.include.cstar" }
          },
          "end": "(?=;|$)",
          "patterns": [
            { "include": "#strings" },
            {
              "name": "keyword.operator.alias.cstar",
              "match": "\\bas\\b"
            },
            {
              "name": "entity.name.namespace.cstar",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
            }
          ]
        },
        {
          "name": "keyword.control.export.cstar",
          "match": "\\bexport\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.struct.cstar",
          "match": "\\b(struct)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.struct.cstar" },
            "2": { "name": "entity.name.type.struct.cstar" }
          }
        },
        {
          "name": "meta.trait.cstar",
          "match": "\\b(trait)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.trait.cstar" },
            "2": { "name": "entity.name.type.trait.cstar" }
          }
        },
        {
          "name": "meta.protocol.cstar",
          "match": "\\b(protocol)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.protocol.cstar" },
            "2": { "name": "entity.name.type.protocol.cstar" }
          }
        },
        {
          "name": "meta.enum.cstar",
          "match": "\\b(enum)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.enum.cstar" },
            "2": { "name": "entity.name.type.enum.cstar" }
          }
        },
        {
          "name": "meta.macro.cstar",
          "match": "\\b(macro)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.macro.cstar" },
            "2": { "name": "entity.name.function.macro.cstar" }
          }
        },
        {
          "name": "storage.type.lifecycle.cstar",
          "match": "\\b(constructor|destructor)\\b"
        },
        {
          "name": "storage.type.attribute.cstar",
          "match": "\\b(attribute|prototype|state)\\b"
        },
        {
          "name": "meta.operator.declaration.cstar",
          "match": "\\b(operator)\\s*(==|!=|<=|>=|<<|>>|&&|\\|\\||::|\\.\\.\\.|\\.\\.|:=|\\.=|[-+*/%<>=!&|^~]|[A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.operator.cstar" },
            "2": { "name": "entity.name.function.operator.cstar" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "punctuation.operator.varargs.cstar",
          "match": "\\.\\.\\."
        },
        {
          "name": "punctuation.operator.assignment.policy.cstar",
          "match": "\\.="
        },
        {
          "name": "punctuation.operator.assignment.move.cstar",
          "match": ":="
        },
        {
          "name": "punctuation.accessor.scope.cstar",
          "match": "::"
        },
        {
          "name": "punctuation.operator.range.cstar",
          "match": "\\.\\."
        },
        {
          "name": "punctuation.operator.comparison.cstar",
          "match": "==|!=|<=|>="
        },
        {
          "name": "punctuation.operator.logical.cstar",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "punctuation.operator.bitwise.cstar",
          "match": "<<|>>|&|\\||\\^|~"
        },
        {
          "name": "punctuation.operator.assignment.cstar",
          "match": "\\+=|-=|\\*=|/=|%=|="
        },
        {
          "name": "punctuation.operator.arithmetic.cstar",
          "match": "[-+*/%]"
        },
        {
          "name": "punctuation.operator.comparison.cstar",
          "match": "[<>]"
        },
        {
          "name": "punctuation.operator.member.cstar",
          "match": "\\."
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.conditional.cstar",
          "match": "\\b(if|elif|else|match|case|default|option)\\b"
        },
        {
          "name": "keyword.control.loop.cstar",
          "match": "\\b(loop|for|in|break|continue)\\b"
        },
        {
          "name": "keyword.control.flow.cstar",
          "match": "\\b(ret|throw|defer|drop)\\b"
        },
        {
          "name": "keyword.operator.ownership.cstar",
          "match": "\\b(ref|deref|move|strong_count|new|shared)\\b"
        },
        {
          "name": "keyword.operator.cast.cstar",
          "match": "\\b(cast|unsafe_cast|sizeof|typeof|is|as)\\b"
        },
        {
          "name": "storage.modifier.visibility.cstar",
          "match": "\\b(public|private)\\b"
        },
        {
          "name": "storage.modifier.cstar",
          "match": "\\b(static|dynamic|extern|native|const|constptr|constref|readonly|nomove|async|await|except|noexcept|onexcept|involved|with|allocator|unsafe)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.cstar",
          "match": "\\b(void|bool|char|uchar|int|uint|int8|int16|int32|int64|uint8|uint16|uint32|uint64|isize|usize|float|float32|float64|any)\\b"
        },
        {
          "name": "entity.name.type.cstar",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.cstar",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.nil.cstar",
          "match": "\\b(nil|null)\\b"
        },
        {
          "name": "variable.language.self.cstar",
          "match": "\\b(self)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.cstar",
          "match": "\\b((0x[0-9A-Fa-f]+)|(\\d+))(\\.\\d+)([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.hex.cstar",
          "match": "\\b0x[0-9A-Fa-f]+\\b"
        },
        {
          "name": "constant.numeric.integer.binary.cstar",
          "match": "\\b0b[01]+\\b"
        },
        {
          "name": "constant.numeric.integer.cstar",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.declaration.cstar",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.cstar" }
          }
        },
        {
          "name": "support.function.std.cstar",
          "match": "\\b(core_print|core_println|core_print_char|core_print_i32|core_print_i64|core_print_f64|core_read_i32|core_read_i64|core_read_string|printf|scanf|getchar)\\b"
        }
      ]
    },
    "members": {
      "patterns": [
        {
          "name": "variable.other.member.cstar",
          "match": "(?<=\\.)[A-Za-z_][A-Za-z0-9_]*\\b"
        },
        {
          "name": "entity.name.function.static.cstar",
          "match": "(?<=::)[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.cstar",
          "match": "[,;:]"
        },
        {
          "name": "punctuation.section.braces.cstar",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.parens.cstar",
          "match": "[()]"
        },
        {
          "name": "punctuation.section.brackets.cstar",
          "match": "[\\[\\]]"
        }
      ]
    }
  }
}
