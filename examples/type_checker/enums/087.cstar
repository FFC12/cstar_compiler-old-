// expected: diagnostic
// expected-code: CST2001

enum Color : uint8 {
    Red,
    Green,
}

main() :: int32 {
    Color color = Color.Red;

    option (color) {
        Color.Red: {
            ret 1;
        },
        Color.Red: {
            ret 2;
        },
        _: {
            ret 0;
        }
    }

    ret 0;
}
