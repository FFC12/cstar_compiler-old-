// expected: diagnostic

struct FileHandle {
    int32 raw;

    constructor() {
        self.raw = 0;
        ret;
    }

    open() :: void {
        self.raw = 1;
        ret;
    }
}

protocol FileState for FileHandle {
    state closed, opened;
    default closed;

    closed -> opened :: open();
}

make_open_file() :: opened FileHandle {
    closed FileHandle file = FileHandle();
    ret file;
}

main() :: int32 {
    opened FileHandle file = make_open_file();
    ret file.raw;
}
