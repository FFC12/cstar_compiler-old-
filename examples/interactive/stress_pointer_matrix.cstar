include "../../std/core.cstar" as core

// expected: interactive

fold3(int32 first, int32 second, int32 third) :: int32 {
    int32 total = first + second;
    total += third;
    ret total;
}

spread_write(int32** slot, int32 value, int32 delta) :: int32 {
    **slot = value;
    **slot += delta;
    ret **slot;
}

readonly_pick(readonly int32* value) :: int32 {
    ret deref value;
}

constptr_mark(constptr int32* value, int32 guard) :: int32 {
    if (guard > 0) {
        deref value = 9;
    } else {
        deref value = 1;
    }

    ret deref value;
}

score_gate(int32 score, int32 guard) :: int32 {
    if (score == guard) {
        core.core_print("gate: exact\n");
        ret 1;
    } elif (score > guard) {
        core.core_print("gate: above\n");
        ret 2;
    }

    core.core_print("gate: below\n");
    ret 3;
}

main() :: int32 {
    core.core_print("C* pointer matrix stress\n");
    core.core_print("matrix name: ");
    core.core_print(core.core_read_string());
    core.core_print("\n");
    core.core_print("cell 0: ");
    int64 aInput = core.core_read_i64();
    core.core_print("cell 1: ");
    int64 bInput = core.core_read_i64();
    core.core_print("cell 2: ");
    int64 cInput = core.core_read_i64();
    core.core_print("delta: ");
    int64 deltaInput = core.core_read_i64();
    core.core_print("guard: ");
    int64 guardInput = core.core_read_i64();

    int32 a = cast<int32>(aInput);
    int32 b = cast<int32>(bInput);
    int32 c = cast<int32>(cInput);
    int32 delta = cast<int32>(deltaInput);
    int32 guard = cast<int32>(guardInput);

    int32 cells[5] = (0, 0, 0, 0, 0);
    cells[0] = a;
    cells[1] = b;
    cells[2] = c;
    cells[3] = fold3(cells[0], cells[1], cells[2]);
    cells[4] = delta;

    int32 target = cells[3];
    int32* targetPtr = ref target;
    int32** targetSlot = ref targetPtr;

    int32 spread = spread_write(targetSlot, cells[3], cells[4]);
    int32 readonlyValue = readonly_pick(targetPtr);
    constptr int32* stableTarget = ref target;
    int32 constptrValue = constptr_mark(stableTarget, guard);

    int32* sharedA = ref target;
    int32* sharedB = sharedA;
    int32* sharedC;
    sharedC := sharedB;
    int32 count = strong_count(sharedA) as int32;

    int32 unsafeFlag = 0;
    int32* raw = unsafe_cast<int32*>(1);
    if (raw) {
        unsafeFlag = 1;
    }

    core.core_print("spread: ");
    core.core_print_i64(spread);
    core.core_print("\n");
    core.core_print("readonly: ");
    core.core_print_i64(readonlyValue);
    core.core_print("\n");
    core.core_print("constptr: ");
    core.core_print_i64(constptrValue);
    core.core_print("\n");
    core.core_print("shared count: ");
    core.core_print_i64(count);
    core.core_print("\n");
    core.core_print("unsafe flag: ");
    core.core_print_i64(unsafeFlag);
    core.core_print("\n");

    ret score_gate(target, guard);
}
