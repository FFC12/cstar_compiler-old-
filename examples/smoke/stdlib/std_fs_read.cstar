// expected-exit: 21

include "../../../std/fs.cstar" as fs

main() :: int32 {
  char buffer[4096];
  fs.FileReadResult result = fs.read_text_4096(
      "examples/smoke/stdlib/data/fs_sample.txt", buffer);

  int64 length = result.length;
  int32 score = 0;
  if (length >= 11) {
    score += 12;
  }
  if (result.success()) {
    score += 4;
  }
  if (fs.fs_ok(result)) {
    score += 5;
  }

  ret score;
}
