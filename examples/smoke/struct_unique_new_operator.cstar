// expected: pass
// expected-exit: 9

struct Meter {
  int32 value;

  constructor(int32 initial) {
    self.value = initial;
    ret;
  }

  destructor() {
    self.value = 0;
    ret;
  }
}

main() :: int32 {
  Meter^ meter = new Meter(9);
  int32 value = meter.value;
  drop meter;
  ret value;
}
