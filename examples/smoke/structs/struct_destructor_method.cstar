// expected: pass
// expected-exit: 7

int32 cleaned = 0;

struct Resource {
  int32 value;

  constructor(int32 initial) {
    self.value = initial;
    ret;
  }

  destructor() {
    cleaned = 7;
    ret;
  }
}

main() :: int32 {
  Resource resource = Resource(9);
  drop resource;
  ret cleaned;
}
