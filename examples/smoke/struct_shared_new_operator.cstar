// expected: pass
// expected-exit: 2

struct Meter {
  int32 value;

  constructor(int32 initial) {
    self.value = initial;
    ret;
  }

  destructor() {
    self.value = 0;
    ret;
  }
}

main() :: int32 {
  Meter* first = shared new Meter(5);
  Meter* second = first;
  int32 count = strong_count(first);
  drop second;
  drop first;
  ret count;
}
