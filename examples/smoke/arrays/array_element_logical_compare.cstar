contains_pair(int32[4] xs, int32[4] ys, int32 x, int32 y) :: bool {
  int32 index = 0;
  loop (index < 4) {
    if (xs[index] == x && ys[index] == y) {
      ret true;
    }
    index += 1;
  }

  ret false;
}

main() :: int32 {
  int32 xs[4] = (1, 3, 5, 7);
  int32 ys[4] = (2, 4, 6, 8);

  if (contains_pair(xs, ys, 5, 6)) {
    ret 1;
  }

  ret 0;
}
