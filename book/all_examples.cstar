// FILE 111: examples/smoke/struct_value_operator_arithmetic.cstar
// expected: pass
// expected-exit: 12

struct Score {
  int32 value;

  constructor(int32 value) {
    self.value = value;
  }

  operator -(Score rhs) :: Score {
    Score result = Score(self.value - rhs.value);
    ret result;
  }

  operator *(Score rhs) :: Score {
    Score result = Score(self.value * rhs.value);
    ret result;
  }

  operator /(Score rhs) :: Score {
    Score result = Score(self.value / rhs.value);
    ret result;
  }

  operator %(Score rhs) :: Score {
    Score result = Score(self.value % rhs.value);
    ret result;
  }
}

main() :: int32 {
  Score a = Score(20);
  Score b = Score(6);
  Score two = Score(2);
  Score three = Score(3);
  Score five = Score(5);
  Score c = a - b;
  Score d = c * two;
  Score e = d / three;
  Score f = d % five;
  ret e.value + f.value;
}
-------

// FILE 112: examples/smoke/struct_value_operator_comparison.cstar
// expected: pass
// expected-exit: 6

struct Rank {
  int32 value;

  constructor(int32 value) {
    self.value = value;
  }

  operator ==(Rank rhs) :: bool {
    ret self.value == rhs.value;
  }

  operator !=(Rank rhs) :: bool {
    ret self.value != rhs.value;
  }

  operator <(Rank rhs) :: bool {
    ret self.value < rhs.value;
  }

  operator <=(Rank rhs) :: bool {
    ret self.value <= rhs.value;
  }

  operator >(Rank rhs) :: bool {
    ret self.value > rhs.value;
  }

  operator >=(Rank rhs) :: bool {
    ret self.value >= rhs.value;
  }
}

main() :: int32 {
  Rank low = Rank(2);
  Rank sameLow = Rank(2);
  Rank high = Rank(7);
  Rank sameHigh = Rank(7);
  int32 score = 0;

  if (low == sameLow) {
    score += 1;
  }
  if (low != high) {
    score += 1;
  }
  if (low < high) {
    score += 1;
  }
  if (low <= sameLow) {
    score += 1;
  }
  if (high > low) {
    score += 1;
  }
  if (high >= sameHigh) {
    score += 1;
  }

  ret score;
}
-------

