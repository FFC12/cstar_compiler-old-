{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "C*",
  "scopeName": "source.cstar",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#characters" },
    { "include": "#directives" },
    { "include": "#imports" },
    { "include": "#declarations" },
    { "include": "#generic-arguments" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#variables" },
    { "include": "#functions" },
    { "include": "#members" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.cstar",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-slash.cstar",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.cstar",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.cstar",
              "match": "\\\\(x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|U[0-9A-Fa-f]{8}|[0-7]{1,3}|[abfnrtv\\\\'\"?0])"
            },
            {
              "name": "constant.other.placeholder.cstar",
              "match": "%([-+ #0]*)(\\d+|\\*)?(\\.(\\d+|\\*))?(hh|h|ll|l|j|z|t|L)?[diuoxXfFeEgGaAcspn%]"
            }
          ]
        }
      ]
    },
    "characters": {
      "patterns": [
        {
          "name": "string.quoted.single.cstar",
          "match": "'([^'\\\\]|\\\\(x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|U[0-9A-Fa-f]{8}|[0-7]{1,3}|[abfnrtv\\\\'\"?0]))'"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "keyword.control.directive.conditional.cstar",
          "match": "#\\s*(if|else|for|warning|error)\\b"
        },
        {
          "name": "keyword.control.directive.cstar",
          "match": "(@|#)\\s*[A-Za-z_][A-Za-z0-9_]*\\b"
        },
        {
          "name": "variable.language.macro.cstar",
          "match": "\\$[A-Za-z_][A-Za-z0-9_]*\\b|\\$[0-9]+\\b"
        },
        {
          "name": "keyword.control.emit.cstar",
          "match": "\\$emit\\b"
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "meta.import.cstar",
          "begin": "\\b(import)\\s+(from)\\b",
          "beginCaptures": {
            "1": { "name": "keyword.control.import.cstar" },
            "2": { "name": "keyword.control.import.from.cstar" }
          },
          "end": "(?=\\{|;|$)",
          "patterns": [
            { "include": "#strings" },
            {
              "name": "entity.name.namespace.cstar",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*(::|;|\\{|$))"
            }
          ]
        },
        {
          "name": "meta.include.cstar",
          "begin": "\\b(include)\\b",
          "beginCaptures": {
            "1": { "name": "keyword.control.include.cstar" }
          },
          "end": "(?=;|$)",
          "patterns": [
            { "include": "#strings" },
            {
              "name": "keyword.operator.alias.cstar",
              "match": "\\bas\\b"
            },
            {
              "name": "entity.name.namespace.cstar",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
            }
          ]
        },
        {
          "name": "keyword.control.export.cstar",
          "match": "\\bexport\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.struct.cstar",
          "match": "\\b(struct)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.struct.cstar" },
            "2": { "name": "entity.name.type.struct.cstar" }
          }
        },
        {
          "name": "meta.trait.cstar",
          "match": "\\b(trait)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.trait.cstar" },
            "2": { "name": "entity.name.type.trait.cstar" }
          }
        },
        {
          "name": "meta.protocol.cstar",
          "match": "\\b(?:(dynamic)\\s+)?(protocol)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.modifier.dynamic.cstar" },
            "2": { "name": "storage.type.protocol.cstar" },
            "3": { "name": "entity.name.type.protocol.cstar" }
          }
        },
        {
          "name": "meta.enum.cstar",
          "match": "\\b(?:(flags)\\s+)?(enum)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.modifier.flags.cstar" },
            "2": { "name": "storage.type.enum.cstar" },
            "3": { "name": "entity.name.type.enum.cstar" }
          }
        },
        {
          "name": "meta.tagged.cstar",
          "match": "\\b(tagged)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.tagged.cstar" },
            "2": { "name": "entity.name.type.tagged.cstar" }
          }
        },
        {
          "name": "meta.macro.cstar",
          "match": "\\b(macro)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.macro.cstar" },
            "2": { "name": "entity.name.function.macro.cstar" }
          }
        },
        {
          "name": "storage.type.lifecycle.cstar",
          "match": "\\b(constructor|destructor|allocator)\\b"
        },
        {
          "name": "storage.type.attribute.cstar",
          "match": "\\b(attribute|prototype|state|default|scope_exit)\\b"
        },
        {
          "name": "meta.operator.declaration.cstar",
          "match": "\\b(operator)\\s*(==|!=|<=|>=|<<|>>|&&|\\|\\||::|\\.\\.\\.|\\.\\.|:=|\\.=|[-+*/%<>=!&|^~]|[A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.operator.cstar" },
            "2": { "name": "entity.name.function.operator.cstar" }
          }
        }
      ]
    },
    "generic-arguments": {
      "patterns": [
        {
          "name": "meta.generic.arguments.cstar",
          "begin": "(?<=[A-Za-z0-9_])<",
          "end": ">",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.typeparameters.begin.cstar" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.typeparameters.end.cstar" }
          },
          "patterns": [
            { "include": "#generic-arguments" },
            { "include": "#types" },
            { "include": "#keywords" },
            {
              "name": "punctuation.separator.generic.cstar",
              "match": ",|::"
            },
            {
              "name": "meta.operator.pointer.cstar",
              "match": "\\*|\\^|&|\\?"
            }
          ]
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "meta.operator.varargs.cstar",
          "match": "\\.\\.\\."
        },
        {
          "name": "meta.operator.allocation.fallible.cstar",
          "match": "\\bnew\\?"
        },
        {
          "name": "meta.operator.nullable.cstar",
          "match": "\\?"
        },
        {
          "name": "meta.operator.assignment.policy.cstar",
          "match": "\\.="
        },
        {
          "name": "meta.operator.assignment.move.cstar",
          "match": ":="
        },
        {
          "name": "punctuation.accessor.scope.cstar",
          "match": "::"
        },
        {
          "name": "meta.operator.range.cstar",
          "match": "\\.\\."
        },
        {
          "name": "meta.operator.comparison.cstar",
          "match": "==|!=|<=|>="
        },
        {
          "name": "meta.operator.logical.cstar",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "meta.operator.increment-decrement.cstar",
          "match": "\\+\\+|--"
        },
        {
          "name": "meta.operator.arrow.cstar",
          "match": "->|=>"
        },
        {
          "name": "meta.operator.bitwise.cstar",
          "match": "<<|>>|&|\\||\\^|~"
        },
        {
          "name": "meta.operator.assignment.cstar",
          "match": "\\+=|-=|\\*=|/=|%=|="
        },
        {
          "name": "meta.operator.arithmetic.cstar",
          "match": "[-+*/%]"
        },
        {
          "name": "meta.operator.comparison.cstar",
          "match": "[<>]"
        },
        {
          "name": "punctuation.accessor.member.cstar",
          "match": "\\."
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.conditional.cstar",
          "match": "\\b(if|elif|else|match|case|default|option)\\b"
        },
        {
          "name": "keyword.control.loop.cstar",
          "match": "\\b(loop|for|in|break|continue)\\b"
        },
        {
          "name": "keyword.control.flow.cstar",
          "match": "\\b(ret|throw|defer|drop|scope_exit)\\b"
        },
        {
          "name": "keyword.operator.ownership.cstar",
          "match": "\\b(ref|deref|move|strong_count|new\\?|new|shared)\\b"
        },
        {
          "name": "keyword.operator.cast.cstar",
          "match": "\\b(cast|unsafe_cast|sizeof|typeof|is|as)\\b"
        },
        {
          "name": "storage.modifier.visibility.cstar",
          "match": "\\b(public|private)\\b"
        },
        {
          "name": "storage.modifier.cstar",
          "match": "\\b(static|dynamic|extern|native|const|constptr|constref|readonly|nomove|async|await|except|noexcept|onexcept|involved|with|allocator|unsafe|closed|opened|idle|sending|failed)\\b"
        },
        {
          "name": "storage.type.meta-kind.cstar",
          "match": "\\b(expr|stmt|item|type|ident|tokens|function|field|method)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.cstar",
          "match": "\\b(void|bool|char|uchar|int|uint|int8|int16|int32|int64|uint8|uint16|uint32|uint64|uint128|isize|usize|float|float32|float64|any|vec2|vec3|vec4|dyn)\\b"
        },
        {
          "name": "entity.name.type.cstar",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.cstar",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.nil.cstar",
          "match": "\\b(nil|null)\\b"
        },
        {
          "name": "variable.language.self.cstar",
          "match": "\\b(self)\\b"
        },
        {
          "name": "constant.other.placeholder.cstar",
          "match": "\\b_\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.cstar",
          "match": "\\b((0x[0-9A-Fa-f]+)|(\\d+))(\\.\\d+)([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.hex.cstar",
          "match": "\\b0x[0-9A-Fa-f]+\\b"
        },
        {
          "name": "constant.numeric.integer.binary.cstar",
          "match": "\\b0b[01]+\\b"
        },
        {
          "name": "constant.numeric.integer.cstar",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "meta.variable.declaration.cstar",
          "match": "\\b(?:(?:const|constptr|constref|readonly|nomove|public|private|static|dynamic|shared)\\s+)*(?:void|bool|char|uchar|int|uint|int8|int16|int32|int64|uint8|uint16|uint32|uint64|uint128|isize|usize|float|float32|float64|any|vec2|vec3|vec4|dyn|[A-Z][A-Za-z0-9_]*)(?:\\s*(?:\\[[^\\]]*\\]|[*^&?]))*\\s+([a-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "variable.other.definition.cstar" }
          }
        },
        {
          "name": "meta.assignment.lhs.cstar",
          "match": "\\b([a-z_][A-Za-z0-9_]*)\\b\\s*(?=(?:=|:=|\\.=|\\+=|-=|\\*=|/=|%=|<<=|>>=|&=|\\|=|\\^=))",
          "captures": {
            "1": { "name": "variable.other.assignment.cstar" }
          }
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.declaration.cstar",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.cstar" }
          }
        },
        {
          "name": "support.function.std.cstar",
          "match": "\\b(core_print|core_println|core_print_char|core_print_i32|core_print_i64|core_print_f64|core_read_i32|core_read_i64|core_read_string|printf|scanf|getchar)\\b"
        }
      ]
    },
    "members": {
      "patterns": [
        {
          "name": "variable.other.member.cstar",
          "match": "(?<=\\.)[A-Za-z_][A-Za-z0-9_]*\\b"
        },
        {
          "name": "entity.name.function.static.cstar",
          "match": "(?<=::)[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.cstar",
          "match": "[,;:]"
        },
        {
          "name": "punctuation.section.braces.cstar",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.parens.cstar",
          "match": "[()]"
        },
        {
          "name": "punctuation.section.brackets.cstar",
          "match": "[\\[\\]]"
        }
      ]
    }
  }
}
